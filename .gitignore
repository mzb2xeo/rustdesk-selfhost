**/node_modules/
**/dist/
**/release/
**/runtime/
**/debian-build/
**/debian/.debhelper/
**/debian/debhelper-build-stamp
**/.vscode/
**/.idea/
**/*.db
**/*.sqlite3
rustdesk-server/id*
