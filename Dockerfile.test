FROM rust:1.96-bookworm

RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        build-essential \
        clang \
        cmake \
        git \
        libasound2-dev \
        libayatana-appindicator3-dev \
        libgstreamer-plugins-base1.0-dev \
        libgstreamer1.0-dev \
        libgtk-3-dev \
        libpam0g-dev \
        libpulse-dev \
        libsodium-dev \
        libssl-dev \
        libudev-dev \
        libunwind-dev \
        libwayland-dev \
        libx11-dev \
        libxcb1-dev \
        libxfixes-dev \
        libxinerama-dev \
        libxkbcommon-dev \
        libxrandr-dev \
        libxtst-dev \
        nasm \
        pkg-config \
        sqlite3 && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /workspace/RustDesk/rustdesk-server

ENV DATABASE_URL=sqlite://./db_v2.sqlite3

CMD ["cargo", "test", "-p", "hbb_common", "--test", "rendezvous_compat"]
