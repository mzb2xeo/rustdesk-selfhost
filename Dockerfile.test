FROM rust:1.96-bookworm

RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        build-essential \
        clang \
        cmake \
        git \
        libasound2-dev \
        libaom-dev \
        libayatana-appindicator3-dev \
        libgstreamer-plugins-base1.0-dev \
        libgstreamer1.0-dev \
        libgtk-3-dev \
        libopus-dev \
        libpam0g-dev \
        libpulse-dev \
        libsodium-dev \
        libssl-dev \
        libudev-dev \
        libunwind-dev \
        libvpx-dev \
        libwayland-dev \
        libx11-dev \
        libxcb1-dev \
        libxfixes-dev \
        libxinerama-dev \
        libxkbcommon-dev \
        libxrandr-dev \
        libxtst-dev \
        libyuv-dev \
        nasm \
        pkg-config \
        sqlite3 && \
    printf '%s\n' \
        'prefix=/usr' \
        'libdir=${prefix}/lib/x86_64-linux-gnu' \
        'includedir=${prefix}/include' \
        '' \
        'Name: libyuv' \
        'Description: YUV conversion and scaling library' \
        'Version: 0.0.1857' \
        'Libs: -L${libdir} -lyuv' \
        'Cflags: -I${includedir}' \
        > /usr/lib/x86_64-linux-gnu/pkgconfig/libyuv.pc && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /workspace/RustDesk/rustdesk-server

ENV DATABASE_URL=sqlite://./db_v2.sqlite3

CMD ["cargo", "test", "-p", "hbb_common", "--test", "rendezvous_compat"]
