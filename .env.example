# ------------------------------------------------------------------------------
# RUSTDESK DOCKER COMPOSE CONFIGURATION
# ------------------------------------------------------------------------------

# Tên miền của máy chủ RustDesk (ví dụ: rustdesk.example.com)
DOMAIN=rustdesk.yourdomain.com

# Múi giờ của hệ thống
TZ=Asia/Ho_Chi_Minh

# Khóa bảo mật JWT (Nhập một chuỗi ngẫu nhiên dài để bảo mật ứng dụng)
JWT_SECRET=your_super_secret_jwt_key_here
