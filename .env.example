# ------------------------------------------------------------------------------
# RUSTDESK DOCKER COMPOSE CONFIGURATION
# ------------------------------------------------------------------------------

# Tên miền của máy chủ RustDesk (ví dụ: rustdesk.example.com)
DOMAIN=rd.yourdomain.com

# Domain cho Web Admin/API/WebSocket (vÃ­ dá»¥: rustdesk.example.com)
DOMAIN_API=rustdesk.yourdomain.com

# Múi giờ của hệ thống
TZ=Asia/Ho_Chi_Minh

# Khóa bảo mật JWT (Nhập một chuỗi ngẫu nhiên dài để bảo mật ứng dụng)
JWT_SECRET=your_super_secret_jwt_key_here

# Bắt buộc RustDesk client phải đăng nhập trước khi kết nối: Y hoặc N
MUST_LOGIN=N

# DB mặc định dùng SQLite và lưu tại ./data/api/rustdeskapi.db.
# Với triển khai lớn hơn, có thể chuyển API sang MySQL/PostgreSQL bằng các biến RUSTDESK_API_GORM_*.
# RUSTDESK_API_GORM_TYPE=sqlite
